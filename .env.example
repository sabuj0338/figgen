# Required for Gemini models
GEMINI_API_KEY="your_google_ai_studio_key"

# Required for OpenAI models (DeepSeek via OpenRouter is also supported)
OPENAI_API_KEY="your_openai_key"
# OPENAI_BASE_URL="https://openrouter.ai/api/v1"

# Required for Anthropic models
ANTHROPIC_API_KEY="your_anthropic_key"

# (Optional) If you are using Ollama, no API key is required. Make sure Ollama is running.
OLLAMA_HOST="http://localhost:11434"

# Set your default LLM provider ("gemini", "openai", "anthropic", "ollama")
DEFAULT_PROVIDER="gemini"

# Set your default model (e.g., "gemini-2.5-pro", "gpt-4o", "claude-3-5-sonnet-20240620")
DEFAULT_MODEL=""

# Required to fetch design data via MCP. Create a Personal Access Token in your Figma account settings.
FIGMA_TOKEN="your_figma_personal_access_token"
