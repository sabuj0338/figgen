# AI Provider Setup (DeepSeek via OpenRouter recommended for low cost)
DEFAULT_PROVIDER="openai"
DEFAULT_MODEL="deepseek/deepseek-chat"
OPENAI_BASE_URL="https://openrouter.ai/api/v1"
OPENAI_API_KEY="sk-or-your-openrouter-key"

# Required for downloading images from Figma during 'figgen run'
FIGMA_TOKEN="your_figma_personal_access_token"

# Required to link the Figma document for image fetching
FIGMA_URL="https://www.figma.com/design/XXXXX/..."


